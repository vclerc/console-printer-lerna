{
    "release-type": "node",
    "always-update": true,
    "separate-pull-requests": false,
    "packages": {
        "packages/test-server": {
            "component": "test",
            "include-component-in-tag": false
        },
        "packages/test-server-alt": {
            "component": "test2",
            "skip-github-release": true
        }
    },
    "plugins": [
        {
            "type": "linked-versions",
            "groupName": "main-group",
            "updateAllPackages": true,
            "components": [
                "test",
                "test2"
            ]
        }
    ]
}
