{
    "bootstrap-sha": "85d5f17ea323e226581b516ad24bf348a2f39477",
    "release-type": "node",
    "always-update": true,
    "separate-pull-requests": false,
    "pull-request-title-pattern": "chore(release): release yuba ${version} (target: ${scope})",
    "packages": {
        "packages/test-server": {
            "component": "test",
            "component-no-space": true
        },
        "packages/test-server-alt": {
            "component": "test2",
            "component-no-space": true
        }
    },
    "plugins": [
        {
            "type": "linked-versions",
            "group-name": "servers",
            "updateAllPackages": true,
            "components": [
                "test",
                "test2"
            ]
        }
    ]
}
